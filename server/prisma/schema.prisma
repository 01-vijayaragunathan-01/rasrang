generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                @id @default(uuid())
  email               String                @unique
  password            String?
  name                String
  regNo               String?               @unique
  role                Role                  @default(STUDENT)
  googleId            String?               @unique
  refreshToken        String?               @unique
  clgName             String?
  year                String?
  dept                String?
  branch              String?
  section             String?
  phoneNo             String?               @unique
  isOnboarded         Boolean               @default(false)
  canManagePrivileges Boolean               @default(false)
  createdAt           DateTime              @default(now())
  avatarSeed          String?
  registrations       Registration[]
  managedEvents       VolunteerAssignment[]
}

model Event {
  id                 String                @id @default(uuid())
  title              String
  category           String                @default("General")
  description        String
  date               String
  imageUrl           String?
  isHeadliner        Boolean               @default(false)
  time               String?
  whatsappLink       String?
  venue              String?
  isRegistrationClosed Boolean               @default(false)
  registrations      Registration[]
  assignedVolunteers VolunteerAssignment[]
}

model Gallery {
  id        String   @id @default(uuid())
  imageUrl  String
  caption   String?
  category  String   @default("General")
  createdAt DateTime @default(now())
}

model Registration {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  status    String   @default("CONFIRMED")
  scanned   Boolean  @default(false)
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model VolunteerAssignment {
  id          String   @id @default(uuid())
  volunteerId String
  eventId     String
  assignedAt  DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  volunteer   User     @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@unique([volunteerId, eventId])
}

enum Role {
  STUDENT
  VOLUNTEER
  COORDINATOR
  SUPER_ADMIN
}
